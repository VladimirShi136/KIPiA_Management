<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  Author: vladimir_shi
  Since: 29.08.2025
  * Окно основной таблицы приборов *
-->

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.kipia.management.kipia_management.controllers.DevicesTableController"
           styleClass="devices-stack-pane"
           VBox.vgrow="ALWAYS">
    <VBox fx:id="contentBox" spacing="10" VBox.vgrow="ALWAYS">
        <!-- 1️⃣ СТАТИСТИКА -->
        <VBox styleClass="statistics-pane">
            <!-- Основные цифры -->
            <HBox spacing="10" styleClass="statistics-data" HBox.hgrow="ALWAYS">
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="totalDevicesLabel"
                           text="--"
                           styleClass="stat-total"/>
                    <Label text="Всего приборов"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="workingDevicesLabel"
                           text="--"
                           styleClass="stat-working"/>
                    <Label text="В работе"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="storageDevicesLabel"
                           text="--"
                           styleClass="stat-storage"/>
                    <Label text="Хранение"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="lostDevicesLabel"
                           text="--"
                           styleClass="stat-lost"/>
                    <Label text="Утерян"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="brokenDevicesLabel"
                           text="--"
                           styleClass="stat-broken"/>
                    <Label text="Испорчен"
                           styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
        <!-- 2️⃣ ТАБЛИЦА ПРИБОРОВ -->
        <TableView fx:id="deviceTable"
                   editable="true"
                   VBox.vgrow="ALWAYS">
            <placeholder>
                <Label text="Таблица пуста"/>
            </placeholder>
        </TableView>
    </VBox>
    <!-- FAB кнопка "+" — плавающая, нижний правый угол -->
    <Button fx:id="fabAddButton"
            text="+"
            styleClass="fab"
            onAction="#onFabAddDevice">
        <StackPane.margin>
            <Insets bottom="24" right="24"/>
        </StackPane.margin>
        <tooltip>
            <Tooltip text="Добавить прибор" style="-fx-font-size: 12px;"/>
        </tooltip>
    </Button>
</StackPane>
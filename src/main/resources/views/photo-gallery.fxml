<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  Author: vladimir_shi
  Since: 02.12.2025
  * Окно фотогалереи *
-->
<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.kipia.management.kipia_management.controllers.PhotoGalleryController"
           VBox.vgrow="ALWAYS">
    <VBox fx:id="contentBox"
          styleClass="photo-gallery-root"
          spacing="10"
          VBox.vgrow="ALWAYS">
        <!-- СТАТИСТИКА -->
        <VBox styleClass="statistics-pane" spacing="8">
            <!-- Основная статистика -->
            <HBox spacing="10" styleClass="statistics-data" HBox.hgrow="ALWAYS">
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="locationsCountLabel"
                           text="0"
                           styleClass="stat-total"/>
                    <Label text="мест установки"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="devicesCountLabel"
                           text="0"
                           styleClass="stat-working"/>
                    <Label text="приборов"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="photosCountLabel"
                           text="0"
                           styleClass="stat-storage"/>
                    <Label text="фотографий"
                           styleClass="stat-label"/>
                </VBox>
            </HBox>
            <!-- Фильтрованная статистика (показывается при активных фильтрах) -->
            <HBox fx:id="filteredStatsBox" spacing="10" styleClass="statistics-data"
                  HBox.hgrow="ALWAYS" visible="false" managed="false">
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="filteredLocationsLabel"
                           text="0"
                           styleClass="stat-total"/>
                    <Label text="мест установки"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="filteredDevicesLabel"
                           text="0"
                           styleClass="stat-working"/>
                    <Label text="приборов"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="filteredPhotosLabel"
                           text="0"
                           styleClass="stat-storage"/>
                    <Label text="фотографий"
                           styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label fx:id="devicesWithPhotosLabel"
                           text="0"
                           styleClass="stat-with-photos"/>
                    <Label text="с фото"
                           styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
        <!-- КОНТЕЙНЕР КАРТОЧЕК -->
        <ListView fx:id="cardsListView"
                  VBox.vgrow="ALWAYS"
                  prefWidth="2200"
                  prefHeight="1800"
                  minWidth="600"
                  minHeight="200"
                  maxHeight="Infinity"
                  styleClass="photo-gallery-listview"/>
    </VBox>
</StackPane>
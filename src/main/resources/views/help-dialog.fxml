<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.layout.StackPane?>

<!--
  Author: vladimir_shi
  Since: 24.04.2026
  * Окно-диалог для просмотра справки *
-->
<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kipia.management.kipia_management.controllers.HelpController"
      styleClass="help-dialog">

    <!-- Шапка диалога -->
    <HBox spacing="16" styleClass="top-box">
        <padding>
            <Insets top="20" right="20" bottom="12" left="20"/>
        </padding>

        <!-- Иконка справки -->
        <StackPane prefWidth="40" prefHeight="40" minWidth="40" minHeight="40">
            <SVGPath styleClass="help-icon" content="M12,2 C6.48,2 2,6.48 2,12 s4.48,10 10,10 s10,-4.48 10,-10 S17.52,2 12,2 z M11,7 h2 v2 h-2 z M11,11 h2 v6 h-2 z"/>
        </StackPane>

        <!-- Текст справа от иконки -->
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label fx:id="typeLabel" text="Справка" styleClass="type-label"/>
            <Label fx:id="titleLabel" text="Информация о приложении" styleClass="title-label" wrapText="true"/>
            <Label fx:id="sectionLabel" styleClass="section-label"/>
        </VBox>
    </HBox>

    <!-- Тело с контентом -->
    <VBox fx:id="contentWrapper">
        <padding>
            <Insets top="10" right="20" bottom="8" left="20"/>
        </padding>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" fitToHeight="true" styleClass="help-scroll-pane" visible="false" managed="false">
            <VBox fx:id="helpContent" spacing="15" styleClass="help-content">
                <padding>
                    <Insets top="5" right="5" bottom="5" left="5"/>
                </padding>
            </VBox>
        </ScrollPane>
        <VBox fx:id="helpContentNoScroll" spacing="15" styleClass="help-content">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
        </VBox>
    </VBox>

    <!-- Разделитель -->
    <Region styleClass="help-divider"/>

    <!-- Панель кнопок -->
    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="help-btn-bar">
        <padding>
            <Insets top="12" right="20" bottom="24" left="20"/>
        </padding>
        <Button fx:id="understoodBtn" text="Понятно" onAction="#closeHelp"/>
    </HBox>
</VBox>

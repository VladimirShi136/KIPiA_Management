<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.StackPane?>

<!--
  Author: vladimir_shi
  Since: 15.01.2025
  * Окно настроек *
-->
<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.kipia.management.kipia_management.controllers.SettingsController"
           VBox.vgrow="ALWAYS">

    <VBox fx:id="contentBox"
          spacing="20"
          styleClass="settings-root"
          VBox.vgrow="ALWAYS">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Заголовок -->
        <Label text="Настройки" styleClass="settings-header"/>

        <Separator/>

        <!-- Секция: Синхронизация базы данных -->
        <VBox spacing="10">
            <Label text="Синхронизация базы данных" styleClass="settings-section-title"/>
            <Label text="Обменивайтесь данными между Android и ПК через ZIP-файл"
                   styleClass="settings-section-description" wrapText="true"/>

            <VBox spacing="5">
                <Label fx:id="lastExportTimeLabel"
                       text="Последний экспорт: никогда"
                       styleClass="timestamp-label"/>
                <Label fx:id="lastImportTimeLabel"
                       text="Последний импорт: никогда"
                       styleClass="timestamp-label"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="exportDbBtn"
                        onAction="#exportDatabase"
                        styleClass="settings-button-export"
                        prefWidth="200">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Label text="↑" styleClass="arrow-icon-top"/>
                            <Label text="Экспорт БД" styleClass="export-button-label"/>
                        </HBox>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Экспортировать базу данных в ZIP-архив"/>
                    </tooltip>
                </Button>

                <Button fx:id="importDbBtn"
                        onAction="#importDatabase"
                        styleClass="settings-button-import"
                        prefWidth="200">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Label text="↓" styleClass="arrow-icon-bottom"/>
                            <Label text="Импорт БД" styleClass="import-button-label"/>
                        </HBox>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Импортировать базу данных из ZIP-архива"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>

        <Separator/>

        <!-- Секция: Импорт/Экспорт Excel -->
        <VBox spacing="10">
            <Label text="Работа с Excel таблицами" styleClass="settings-section-title"/>
            <Label text="Заполняйте excel-таблицу для быстрого импорта в базу данных"
                   styleClass="settings-section-description" wrapText="true"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="exportExcelBtn"
                        onAction="#exportToExcel"
                        styleClass="settings-button-export"
                        prefWidth="200">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Label text="↑" styleClass="arrow-icon-top"/>
                            <Label text="Экспорт в Excel" styleClass="export-button-label"/>
                        </HBox>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Экспортировать данные приборов в Excel файл"/>
                    </tooltip>
                </Button>

                <Button fx:id="importExcelBtn"
                        onAction="#importFromExcel"
                        styleClass="settings-button-import"
                        prefWidth="200">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Label text="↓" styleClass="arrow-icon-bottom"/>
                            <Label text="Импорт из Excel" styleClass="import-button-label"/>
                        </HBox>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Импортировать данные приборов из Excel файла"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>

        <Separator/>

        <!-- Информация -->
        <VBox spacing="5">
            <Label text="ℹ Информация по БД:" styleClass="settings-info-title"/>
            <Label text="• Экспорт БД создаёт ZIP-архив с базой данных и фотографиями"
                   styleClass="settings-info-text" wrapText="true"/>
            <Label text="• Импорт БД объединяет данные, сохраняя записи с более поздней датой обновления"
                   styleClass="settings-info-text" wrapText="true"/>
            <Label text="ℹ Информация по Excel:" styleClass="settings-info-title"/>
            <Label text="• Excel файлы содержат только данные приборов без фотографий"
                   styleClass="settings-info-text" wrapText="true"/>
            <Label styleClass="settings-info-text"
                   text="• * — обязательные поля: Тип прибора, Модель, Инв. №, Место установки, Статус."
                   wrapText="true"/>
            <Label styleClass="settings-info-text"
                   text="• Если статус «Хранение» — место установки: СКЛАД"
                   wrapText="true"/>
            <Label styleClass="settings-info-text"
                   text="• Если статус «Утерян» — место установки: УТЕРЯННЫЕ"
                   wrapText="true"/>
        </VBox>
    </VBox>

</StackPane>

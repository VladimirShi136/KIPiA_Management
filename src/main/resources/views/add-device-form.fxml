<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>

<!--
  Author: vladimir_shi
  Since: 30.08.2025
  * Окно добавления нового прибора *
-->
<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kipia.management.kipia_management.controllers.AddDeviceController"
      styleClass="add-device-root"
      style="-fx-background-color: transparent;"
      VBox.vgrow="ALWAYS">

    <!-- ScrollPane для всей формы -->
    <ScrollPane fitToWidth="true"
                style="-fx-background: transparent; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">

        <VBox spacing="20" alignment="TOP_CENTER" style="-fx-padding: 20;">

            <!-- Заголовок -->
            <Label fx:id="formTitleLabel" text="Добавление нового прибора" styleClass="form-header"/>

            <!-- Форма в центрированном контейнере -->
            <VBox spacing="15" alignment="CENTER" prefWidth="500">
                <GridPane hgap="15" vgap="12" styleClass="form-grid">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="180"/>
                        <ColumnConstraints halignment="LEFT" prefWidth="280"/>
                    </columnConstraints>

                    <!-- СТРОКА 0: Тип прибора -->
                    <Label text="* Тип прибора:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                    <TextField fx:id="typeField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="Например, Манометр"/>

                    <!-- СТРОКА 1: Модель -->
                    <Label text="* Модель:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                    <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="Например, МП4-УУ2"/>

                    <!-- СТРОКА 2: Инвентарный номер -->
                    <Label text="* Инвентарный номер:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                    <TextField fx:id="inventoryNumberField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="Например, ТМ-001"/>

                    <!-- СТРОКА 3: Место установки -->
                    <Label text="* Место установки:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                    <ComboBox fx:id="locationField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="280"
                              editable="true" styleClass="form-input" promptText="Например, 88 км Губкин"/>

                    <!-- СТРОКА 4: Кран № -->
                    <Label text="Кран №:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                    <TextField fx:id="valveNumberField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="Например, Р1-333"/>

                    <!-- СТРОКА 5: Статус -->
                    <Label text="* Статус:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
                    <ComboBox fx:id="statusComboBox" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="280"
                              styleClass="form-input" promptText="Выберите статус прибора"/>

                    <!-- СТРОКА 6: Предел измерений -->
                    <Label text="Предел измерений:" GridPane.rowIndex="6" GridPane.columnIndex="0"
                           styleClass="form-label"/>
                    <TextField fx:id="measurementLimitField" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="В кг или МПа"/>

                    <!-- СТРОКА 7: Класс точности -->
                    <Label text="Класс точности:" GridPane.rowIndex="7" GridPane.columnIndex="0"
                           styleClass="form-label"/>
                    <TextField fx:id="accuracyClassField" GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="280"
                               styleClass="form-input" promptText="Введите число в %"/>

                    <!-- СТРОКА 8: Производитель -->
                    <Label text="Производитель:" GridPane.rowIndex="8" GridPane.columnIndex="0"
                           styleClass="form-label"/>
                    <TextField fx:id="manufacturerField" GridPane.rowIndex="8" GridPane.columnIndex="1" prefWidth="280"
                               promptText="Например, ОАО Манотомь" styleClass="form-input"/>

                    <!-- СТРОКА 9: Год выпуска -->
                    <Label text="Год выпуска:" GridPane.rowIndex="9" GridPane.columnIndex="0"
                           styleClass="form-label"/>
                    <TextField fx:id="yearField" GridPane.rowIndex="9" GridPane.columnIndex="1" prefWidth="280"
                               promptText="Год (число), напр. 2023" styleClass="form-input"/>

                    <!-- СТРОКА 10: Доп. информация -->
                    <Label text="Доп. информация:" GridPane.rowIndex="10" GridPane.columnIndex="0"
                           styleClass="form-label"/>
                    <TextArea fx:id="additionalInfoField" GridPane.rowIndex="10" GridPane.columnIndex="1" prefWidth="280"
                              prefHeight="60" wrapText="true" promptText="Любая дополнительная информация"
                              styleClass="form-textarea"/>

                    <!-- СТРОКА 11: Фото -->
                    <Label text="Фото (несколько):" GridPane.rowIndex="11" GridPane.columnIndex="0" styleClass="form-label"/>
                    <HBox spacing="20" GridPane.rowIndex="11" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                        <Button fx:id="photoChooseBtn" onAction="#onChooseFiles"
                                styleClass="photo-icon-btn" prefWidth="24" prefHeight="24">
                            <graphic>
                                <javafx.scene.image.ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                                    <Image url="@../images/image-plus.png"/>
                                </javafx.scene.image.ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="photoRemoveBtn" onAction="#onRemovePhoto"
                                styleClass="photo-icon-btn-with-margin" prefWidth="24" prefHeight="24">
                            <graphic>
                                <javafx.scene.image.ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                                    <Image url="@../images/image-minus.png"/>
                                </javafx.scene.image.ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- СТРОКА 12: Выбранные фото -->
                    <Label text="Выбранные фото:" GridPane.rowIndex="12" GridPane.columnIndex="0" styleClass="form-label"/>
                    <HBox GridPane.rowIndex="12" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                        <VBox spacing="5" prefWidth="280">
                            <ListView fx:id="selectedPhotosListView"
                                      prefHeight="80" prefWidth="280"
                                      styleClass="photo-list"/>
                            <Label fx:id="photoCounterLabel" text="Выбрано файлов: 0"
                                   styleClass="photo-counter"/>
                        </VBox>
                    </HBox>

                    <!-- СТРОКА 13: Последнее обновление -->
                    <Label text="Последнее обновление:" GridPane.rowIndex="13" GridPane.columnIndex="0" styleClass="form-label"/>
                    <Label fx:id="updatedAtLabel" GridPane.rowIndex="13" GridPane.columnIndex="1"/>
                </GridPane>

                <Label text="* — обязательные поля"
                       style="-fx-font-size: 11px; -fx-text-fill: #e74c3c; -fx-font-style: italic;"
                       alignment="CENTER"/>

                <!-- Кнопки - всегда видимы внизу -->
                <HBox spacing="40" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                    <!-- Кнопка удаления — видна только в режиме редактирования -->
                    <Button fx:id="deleteBtn" onAction="#onDeleteDevice"
                            styleClass="button-delete" prefWidth="24" prefHeight="24"
                            visible="false" managed="false">
                        <graphic>
                            <javafx.scene.image.ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                                <Image url="@../images/delete.png"/>
                            </javafx.scene.image.ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="cancelBtn" onAction="#onCancel"
                            styleClass="button-icon" prefWidth="24" prefHeight="24"/>
                    <Button fx:id="addBtn" onAction="#onAddDevice"
                            styleClass="button-icon" prefWidth="24" prefHeight="24"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>